# ─── Banco de Dados ────────────────────────────────────────────────────────────
# PostgreSQL via Supabase
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Autenticação ──────────────────────────────────────────────────────────────
JWT_SECRET="your-secret-key-here"

# ─── Meta Ads (Facebook) ───────────────────────────────────────────────────────
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_REDIRECT_URI="https://ai-adsbackend-production.up.railway.app/integracoes/meta/callback"

# ─── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="https://ai-adsbackend-production.up.railway.app/integracoes/google/callback"
# Solicitar Basic Access em: Google Ads → Ferramentas → Central de API
# Atenção: em modo de teste só acessa contas de teste do Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN="your-google-ads-developer-token"

# ─── IA ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── Redis (BullMQ) ────────────────────────────────────────────────────────────
# Local: docker run -d --name redis-mktai -p 6379:6379 redis:alpine
# Produção Railway: usar REDIS_URL (Railway injeta automaticamente via add-on)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
# REDIS_URL="redis://..." ← Railway/Upstash em produção (substitui HOST+PORT)

# ─── AbacatePay ────────────────────────────────────────────────────────────────
ABACATEPAY_API_KEY="your-abacatepay-api-key"
ABACATEPAY_WEBHOOK_SECRET="your-webhook-secret"

# ─── Servidor ──────────────────────────────────────────────────────────────────
BACKEND_URL="https://ai-adsbackend-production.up.railway.app"
PORT=3000

# ─── Servidor ──────────────────────────────────────────────────────────────────
# URL do frontend — usada no redirect pós-OAuth e no CORS
FRONTEND_URL="http://localhost:5173"

# ─── Frontend / Vercel ─────────────────────────────────────────────────────────
# Configurar no painel da Vercel como variável de ambiente
# Em dev não é necessário (o proxy do Vite cuida disso)
VITE_API_URL="https://ai-adsbackend-production.up.railway.app/api"
