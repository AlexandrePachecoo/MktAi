# ─── Banco de Dados ────────────────────────────────────────────────────────────
# PostgreSQL via Supabase
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Autenticação ──────────────────────────────────────────────────────────────
JWT_SECRET="your-secret-key-here"

# ─── Meta Ads (Facebook) ───────────────────────────────────────────────────────
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_REDIRECT_URI="http://localhost:3000/integracoes/meta/callback"

# ─── Google Ads ────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/integracoes/google/callback"
# Solicitar Basic Access em: Google Ads → Ferramentas → Central de API
# Atenção: em modo de teste só acessa contas de teste do Google Ads
GOOGLE_ADS_DEVELOPER_TOKEN="your-google-ads-developer-token"

# ─── IA ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
IDEOGRAM_API_KEY="your-ideogram-api-key"

# ─── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# ─── Redis (BullMQ) ────────────────────────────────────────────────────────────
# Local: docker run -d --name redis-mktai -p 6379:6379 redis:alpine
# Produção: usar Upstash ou Railway Redis
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# ─── Frontend ──────────────────────────────────────────────────────────────────
# URL do frontend — usada no redirect pós-OAuth
FRONTEND_URL="http://localhost:5173"
